/* ============================================
   TaskFlow — script.js
   Task Tracker Application Logic
   ============================================ */

// ── State ──────────────────────────────────
let tasks = [];         // Array of task objects
let editingId = null;   // ID of task currently being edited
let deleteTargetId = null; // ID of task pending deletion

// ── DOM References ──────────────────────────
const taskForm       = document.getElementById('taskForm');
const taskNameInput  = document.getElementById('taskName');
const deadlineInput  = document.getElementById('deadlineTime');
const completionInput= document.getElementById('completionTime');
const submitBtn      = document.getElementById('submitBtn');
const cancelBtn      = document.getElementById('cancelBtn');
const formTitle      = document.getElementById('formTitle');

const tableBody      = document.getElementById('taskTableBody');
const emptyState     = document.getElementById('emptyState');
const clearAllBtn    = document.getElementById('clearAllBtn');

const totalEl        = document.getElementById('totalTasks');
const onTimeEl       = document.getElementById('onTimeTasks');
const lateEl         = document.getElementById('lateTasks');
const accuracyEl     = document.getElementById('accuracyValue');
const progressFill   = document.getElementById('progressFill');
const progressPct    = document.getElementById('progressPct');

const darkToggle     = document.getElementById('darkToggle');
const toggleIcon     = document.getElementById('toggleIcon');
const toggleLabel    = document.getElementById('toggleLabel');

const modalOverlay   = document.getElementById('modalOverlay');
const confirmDelete  = document.getElementById('confirmDelete');
const cancelDelete   = document.getElementById('cancelDelete');

const nameError      = document.getElementById('nameError');
const deadlineError  = document.getElementById('deadlineError');
const completionError= document.getElementById('completionError');

// ── Utility: Generate unique ID ─────────────
function generateId() {
  return Date.now().toString(36) + Math.random().toString(36).slice(2);
}

// ── Utility: Format datetime for display ────
function formatDateTime(dtStr) {
  if (!dtStr) return '—';
  const d = new Date(dtStr);
  return d.toLocaleString('en-IN', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit', hour12: true
  });
}

// ── Utility: Determine task status ──────────
// On Time if completion <= deadline, else Late
function getStatus(deadline, completion) {
  const d = new Date(deadline);
  const c = new Date(completion);
  return c <= d ? 'on-time' : 'late';
}

// ── LocalStorage: Save tasks ────────────────
function saveTasks() {
  localStorage.setItem('taskflow_tasks', JSON.stringify(tasks));
}

// ── LocalStorage: Load tasks ────────────────
function loadTasks() {
  const stored = localStorage.getItem('taskflow_tasks');
  tasks = stored ? JSON.parse(stored) : [];
}

// ── LocalStorage: Save dark mode preference ─
function saveDarkMode(isDark) {
  localStorage.setItem('taskflow_dark', isDark ? '1' : '0');
}

function loadDarkMode() {
  return localStorage.getItem('taskflow_dark') === '1';
}

// ── Dark Mode: Apply theme ───────────────────
function applyTheme(isDark) {
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
  toggleIcon.textContent  = isDark ? '☀️' : '🌙';
  toggleLabel.textContent = isDark ? 'Light Mode' : 'Dark Mode';
}

// ── Dark Mode: Toggle ────────────────────────
darkToggle.addEventListener('click', () => {
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  applyTheme(!isDark);
  saveDarkMode(!isDark);
});

// ── Stats & Progress Bar: Recalculate ───────
function updateStats() {
  const total   = tasks.length;
  const onTime  = tasks.filter(t => t.status === 'on-time').length;
  const late    = total - onTime;
  const accuracy = total > 0 ? Math.round((onTime / total) * 100) : 0;

  // Update stat cards
  totalEl.textContent    = total;
  onTimeEl.textContent   = onTime;
  lateEl.textContent     = late;
  accuracyEl.textContent = accuracy + '%';

  // Update progress bar
  progressFill.style.width = accuracy + '%';
  progressPct.textContent  = accuracy + '%';
}

// ── Table: Render all tasks ──────────────────
function renderTable() {
  tableBody.innerHTML = '';

  if (tasks.length === 0) {
    emptyState.classList.add('visible');
    updateStats();
    return;
  }

  emptyState.classList.remove('visible');

  tasks.forEach((task, index) => {
    const isOnTime  = task.status === 'on-time';
    const badgeText = isOnTime ? 'On Time ✅' : 'Late ❌';
    const badgeCls  = isOnTime ? 'on-time' : 'late';

    const tr = document.createElement('tr');
    tr.dataset.id = task.id;

    tr.innerHTML = `
      <td>${index + 1}</td>
      <td class="task-name-cell">${escapeHtml(task.name)}</td>
      <td>${formatDateTime(task.deadline)}</td>
      <td>${formatDateTime(task.completion)}</td>
      <td><span class="status-badge ${badgeCls}">${badgeText}</span></td>
      <td class="actions-cell">
        <button class="btn-icon edit" title="Edit" onclick="startEdit('${task.id}')">✏️</button>
        <button class="btn-icon delete" title="Delete" onclick="openDeleteModal('${task.id}')">🗑️</button>
      </td>
    `;
    tableBody.appendChild(tr);
  });

  updateStats();
}

// ── Security: Escape HTML to prevent XSS ────
function escapeHtml(str) {
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

// ── Form Validation ──────────────────────────
function validateForm() {
  let valid = true;

  // Clear previous errors
  clearErrors();

  const name       = taskNameInput.value.trim();
  const deadline   = deadlineInput.value;
  const completion = completionInput.value;

  if (!name) {
    showError(taskNameInput, nameError, 'Task name is required.');
    valid = false;
  }

  if (!deadline) {
    showError(deadlineInput, deadlineError, 'Deadline is required.');
    valid = false;
  }

  if (!completion) {
    showError(completionInput, completionError, 'Completion time is required.');
    valid = false;
  }

  return valid;
}

function showError(inputEl, errorEl, msg) {
  inputEl.classList.add('invalid');
  errorEl.textContent = msg;
}

function clearErrors() {
  [taskNameInput, deadlineInput, completionInput].forEach(el => el.classList.remove('invalid'));
  [nameError, deadlineError, completionError].forEach(el => el.textContent = '');
}

// ── Form Submit: Add or Update task ─────────
taskForm.addEventListener('submit', (e) => {
  e.preventDefault();

  if (!validateForm()) return;

  const name       = taskNameInput.value.trim();
  const deadline   = deadlineInput.value;
  const completion = completionInput.value;
  const status     = getStatus(deadline, completion);

  if (editingId) {
    // Update existing task
    const idx = tasks.findIndex(t => t.id === editingId);
    if (idx !== -1) {
      tasks[idx] = { ...tasks[idx], name, deadline, completion, status };
    }
    stopEditing();
  } else {
    // Add new task
    const newTask = { id: generateId(), name, deadline, completion, status };
    tasks.push(newTask);
  }

  saveTasks();
  renderTable();
  resetForm();
});

// ── Form Reset ───────────────────────────────
function resetForm() {
  taskForm.reset();
  clearErrors();
  taskNameInput.focus();
}

// ── Edit Task: Populate form ─────────────────
function startEdit(id) {
  const task = tasks.find(t => t.id === id);
  if (!task) return;

  editingId = id;

  // Populate form with task values
  taskNameInput.value   = task.name;
  deadlineInput.value   = task.deadline;
  completionInput.value = task.completion;

  // Update UI for edit mode
  formTitle.textContent    = 'Edit Task ✏️';
  submitBtn.innerHTML      = '<span>Update Task</span>';
  cancelBtn.style.display  = 'inline-flex';

  // Scroll to form smoothly
  document.querySelector('.form-section').scrollIntoView({ behavior: 'smooth', block: 'center' });
  taskNameInput.focus();
}

// ── Edit Task: Cancel ────────────────────────
cancelBtn.addEventListener('click', () => {
  stopEditing();
  resetForm();
});

function stopEditing() {
  editingId                = null;
  formTitle.textContent    = 'Add New Task';
  submitBtn.innerHTML      = '<span>Add Task</span>';
  cancelBtn.style.display  = 'none';
}

// ── Delete Modal: Open ───────────────────────
function openDeleteModal(id) {
  deleteTargetId = id;
  modalOverlay.classList.add('active');
}

// ── Delete Modal: Cancel ─────────────────────
cancelDelete.addEventListener('click', () => {
  deleteTargetId = null;
  modalOverlay.classList.remove('active');
});

// ── Delete Modal: Confirm ────────────────────
confirmDelete.addEventListener('click', () => {
  if (deleteTargetId) {
    // Remove task from array
    tasks = tasks.filter(t => t.id !== deleteTargetId);
    deleteTargetId = null;
    saveTasks();
    renderTable();
  }
  modalOverlay.classList.remove('active');
});

// ── Close modal on overlay click ─────────────
modalOverlay.addEventListener('click', (e) => {
  if (e.target === modalOverlay) {
    deleteTargetId = null;
    modalOverlay.classList.remove('active');
  }
});

// ── Clear All Tasks ──────────────────────────
clearAllBtn.addEventListener('click', () => {
  if (tasks.length === 0) return;

  // Reuse modal for clear-all confirmation
  deleteTargetId = '__clear_all__';
  modalOverlay.classList.add('active');
  document.querySelector('.modal-title').textContent   = 'Clear All Tasks?';
  document.querySelector('.modal-icon').textContent    = '⚠️';
  document.querySelector('.modal-desc').textContent    = 'This will remove all tasks permanently.';
});

// Override confirm to also handle clear-all
const originalConfirm = confirmDelete.onclick;
confirmDelete.addEventListener('click', () => {
  if (deleteTargetId === '__clear_all__') {
    tasks = [];
    deleteTargetId = null;
    saveTasks();
    renderTable();
    modalOverlay.classList.remove('active');
    // Reset modal text back
    document.querySelector('.modal-title').textContent = 'Delete Task?';
    document.querySelector('.modal-icon').textContent  = '🗑️';
    document.querySelector('.modal-desc').textContent  = 'This action cannot be undone.';
  }
});

cancelDelete.addEventListener('click', () => {
  // Reset modal text on cancel too
  document.querySelector('.modal-title').textContent = 'Delete Task?';
  document.querySelector('.modal-icon').textContent  = '🗑️';
  document.querySelector('.modal-desc').textContent  = 'This action cannot be undone.';
});

// ── Keyboard: Close modal on Escape ──────────
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && modalOverlay.classList.contains('active')) {
    deleteTargetId = null;
    modalOverlay.classList.remove('active');
    document.querySelector('.modal-title').textContent = 'Delete Task?';
    document.querySelector('.modal-icon').textContent  = '🗑️';
    document.querySelector('.modal-desc').textContent  = 'This action cannot be undone.';
  }
});

// ── Init: Bootstrap the application ─────────
function init() {
  // Restore dark mode preference
  const isDark = loadDarkMode();
  applyTheme(isDark);

  // Load tasks from localStorage
  loadTasks();

  // Render table and stats
  renderTable();
}

// ── Run on page load ─────────────────────────
init();

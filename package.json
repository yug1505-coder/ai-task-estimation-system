{
  "name": "ai-task-estimation-system",
  "version": "1.0.0",
  "description": "AI-Based Task Estimation System with Frontend and Backend",
  "private": true,
  "scripts": {
    "start": "npm run backend:start",
    "dev": "npm run backend:dev",
    "backend:start": "cd backend && npm start",
    "backend:dev": "cd backend && npm run dev",
    "backend:install": "cd backend && npm install",
    "frontend:dev": "cd frontend && python -m http.server 8000",
    "install:all": "npm run backend:install",
    "postinstall": "npm run backend:install"
  },
  "keywords": [
    "ai",
    "task",
    "estimation",
    "system"
  ],
